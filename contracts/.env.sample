# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# Owner of the wrapped parent name, funded with Sepolia faucet ETH.
DEPLOYER_PRIVATE_KEY=0x<your-test-key>

# Public Sepolia RPCs (no key needed). Pick one, or use your own Infura/Alchemy URL.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# SEPOLIA_RPC_URL=https://sepolia.drpc.org
# SEPOLIA_RPC_URL=https://1rpc.io/sepolia

# Optional, for contract verification.
ETHERSCAN_API_KEY=

# namehash of your parent name, e.g. namehash("junto-xyz.eth").
# Compute: cd ../agent && pnpm tsx -e "import('viem/ens').then(m=>console.log(m.namehash('junto-xyz.eth')))"
PARENT_NODE=0x<namehash>

# Set after Deploy.s.sol prints the address:
EVENT_MANAGER=0x<deployed>

# CreateEvent.s.sol inputs (event content lives in ENS records, never hard-coded in the contract):
EVENT_LABEL=ethny
EVENT_TITLE=ETHGlobal NY Kickoff
EVENT_LOCATION=New York
EVENT_CAPACITY=100
