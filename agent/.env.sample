# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# Attendee/agent key, funded with Sepolia faucet ETH.
PRIVATE_KEY=0x<your-test-key>

# Public Sepolia RPCs (no key needed). Pick one, or use your own Infura/Alchemy URL.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# SEPOLIA_RPC_URL=https://sepolia.drpc.org
# SEPOLIA_RPC_URL=https://1rpc.io/sepolia

# Deployed EventManager address (from contracts Deploy.s.sol output).
EVENT_MANAGER=0x<deployed>

# Optional override; defaults to ENS Sepolia PublicResolver.
# PUBLIC_RESOLVER=0xE99638b40E4Fff0129D56f03b55b6bbC4BBE49b5
